# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files
*.tfvars
*.tfvars.json

# Allow example tfvars file
!terraform.tfvars.example

# Terraform plan files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive keys and certificates
*.pem
*.pfx
*.key
*.cer

# VS Code
.vscode/

# Operating system files
Thumbs.db
.DS_Store
